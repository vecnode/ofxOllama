{

	"version": "2.0.0",
	"shell":{
		"task": true
	},
	"windows" : {
		"options": {
			"shell": {
				"executable": "C:\\msys64\\msys2_shell.cmd",
				"args": [
					"-defterm",
					"-mingw64",
					"-no-start",
					"-here",
					"-shell bash -c"
				]
			}
		}
	},
	"problemMatcher": {
		"owner": "cpp",
		"fileLocation": ["relative", "${workspaceFolder}"],
		"pattern": {
			"regexp": "^(.*):(\\d+):(\\d+):\\s+(warning|error):\\s+(.*)$",
			"file": 1,
			"line": 2,
			"column": 3,
			"severity": 4,
			"message": 5
		}
	},

	"group": {
		"kind": "build",
	},

	"presentation": {
		"reveal": "always",
		"panel": "shared"
	},

	"tasks": [
		{
			"type": "shell",
			"label": "Build RELEASE",
			"command": "make -C examples/simpleChatExample -j -s 2>&1",
			"linux": {
				"command": "make -C examples/simpleChatExample -j -s 2>&1"
			},
			"windows": {
				"command": "make -C examples/simpleChatExample -j -s 2>&1"
			}
		},
		{
			"type": "shell",
			"label": "Run RELEASE",
			"command": "make -C examples/simpleChatExample RunRelease >&1",
			"linux": {
				"command": "make -C examples/simpleChatExample RunRelease >&1"
			},
			"windows" : {
				"command" : "make -C examples/simpleChatExample RunRelease >&1"
			}
		},
		{
			"label": "Build and Run Release",
			"dependsOn": ["Build RELEASE", "Run RELEASE"],
			"dependsOrder": "sequence",
			"group": {
				"kind": "build",
				"isDefault": true
			}
		},
		{
			"type": "shell",
			"label": "Build DEBUG",
			"command": "make -C examples/simpleChatExample Debug -j -s 2>&1 || exit 1",
			"linux": {
				"command": "make -C examples/simpleChatExample Debug -j -s 2>&1 || exit 1"
			},
			"windows": {
				"command": "make -C examples/simpleChatExample Debug -j -s 2>&1 || exit 1"
			}
		},

		{
			"type": "shell",
			"label": "Clean DEBUG",
			"command": "make -C examples/simpleChatExample CleanDebug",
			"linux": {
				"command": "make -C examples/simpleChatExample CleanDebug"
			},
			"windows": {
				"command": "make -C examples/simpleChatExample CleanDebug"
			}
		},

		{
			"type": "shell",
			"label": "Clean RELEASE",
			"command": "make -C examples/simpleChatExample CleanRelease",
			"linux": {
				"command": "make -C examples/simpleChatExample CleanRelease"
			},
			"windows": {
				"command": "make -C examples/simpleChatExample CleanRelease"
			}
		},
		{
			"type": "shell",
			"label": "Clean ALL",
			"command": "make -C examples/simpleChatExample clean",
			"linux": {
				"command": "make -C examples/simpleChatExample clean"
			},
			"windows": {
				"command": "make -C examples/simpleChatExample clean"
			}
		}
	]
}
